rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // users/{uid}/ 경로:
    // - 인증된 모든 유저가 읽을 수 있다 (프로필 사진 표시에 필요).
    // - 쓰기는 본인 폴더만 가능하다.
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // photoVerification/{uid}/{fileName} (Phase 3-2):
    //
    // 사진 인증용 셀피. **공개 프로필 사진과 완전히 분리된 비공개 경로다** —
    // users/{uid} 경로와 달리 다른 사용자는 읽을 수 없다.
    // 운영 검토가 끝나면 Admin SDK가 Rules를 우회해 삭제한다.
    //
    // - read: 본인만(제출 상태 확인용).
    // - create: 본인만, 5MB 이하 이미지, 허용 확장자/MIME만.
    // - update/delete: 항상 금지(덮어쓰기 대신 새 uploadId로 재제출한다).
    match /photoVerification/{uid}/{fileName} {
      function validVerificationImage() {
        return request.resource.size <= 5 * 1024 * 1024 &&
          request.resource.contentType in [
            'image/jpeg', 'image/png', 'image/heic', 'image/heif'
          ] &&
          fileName.matches('.*\\.(jpg|jpeg|png|heic|heif)$');
      }

      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null &&
        request.auth.uid == uid &&
        validVerificationImage();
      allow update, delete: if false;
    }

    // affiliationVerification/{uid}/{type}/{fileName} (Phase 3-3):
    //
    // 직장·학교 소속 증빙. 사진 인증과 같은 owner-only 비공개 경로이며,
    // 검토가 끝나면 Admin SDK가 Rules를 우회해 삭제한다.
    // 파일명에는 기관명 등 개인정보를 넣지 않는다(uploadId만).
    match /affiliationVerification/{uid}/{type}/{fileName} {
      function validAffiliationImage() {
        return type in ['work', 'school'] &&
          request.resource.size <= 5 * 1024 * 1024 &&
          request.resource.contentType in [
            'image/jpeg', 'image/png', 'image/heic', 'image/heif'
          ] &&
          fileName.matches('.*\\.(jpg|jpeg|png|heic|heif)$');
      }

      allow read: if request.auth != null &&
        request.auth.uid == uid &&
        type in ['work', 'school'];
      allow create: if request.auth != null &&
        request.auth.uid == uid &&
        validAffiliationImage();
      allow update, delete: if false;
    }

    // communityFeed/{uid}/{postId}/{fileName} (Phase 4-3):
    //
    // 커뮤니티 Feed 게시물 이미지. **download URL을 만들지 않는 경로다** —
    // Firestore에는 이 내부 경로만 저장하고, 표시할 때 인증된 앱 사용자가
    // bytes를 직접 읽는다. 그래서 read를 "인증만 하면 전부"로 열지 않고
    // 대응 게시물이 실제로 살아 있는지 Firestore에서 확인한다.
    //
    // - create: 본인 폴더에만, 5MB 이하 jpg/png만.
    // - read:   active/authenticated 상태인 본인 소유 feed 게시물이 그 경로를
    //           imagePaths에 담고 있을 때만. 글이 삭제되면 즉시 막힌다.
    // - update/delete: 항상 금지. 파일 삭제는 Admin SDK만 수행한다.
    match /communityFeed/{uid}/{postId}/{fileName} {
      // 클라이언트가 만든 Firestore auto-ID 형식만 받는다.
      function validPostId() {
        return postId.matches('^[A-Za-z0-9]{20}$');
      }
      function validFeedImage() {
        return request.resource.size > 0 &&
          request.resource.size <= 5 * 1024 * 1024 &&
          request.resource.contentType in ['image/jpeg', 'image/png'] &&
          fileName.matches('^[A-Za-z0-9_-]{1,64}\\.(jpg|jpeg|png)$');
      }
      function objectPath() {
        return 'communityFeed/' + uid + '/' + postId + '/' + fileName;
      }
      // Storage Rules → Firestore cross-service 조회.
      //
      // 한 번의 Rules 평가에서 읽을 수 있는 Firestore 문서는 최대 2개이고
      // 읽을 때마다 Firestore 할당량·과금이 발생한다. 그래서 exists()+get()으로
      // 같은 문서를 두 번 읽지 않고 get() 한 번만 쓴다. 게시물이 없으면 get()이
      // null을 돌려주고 .data 접근이 평가 오류가 되어 그대로 거부된다.
      function postAllowsRead() {
        let post = firestore.get(
          /databases/(default)/documents/communityPosts/$(postId)
        ).data;
        return post.authorUid == uid &&
          post.surface == 'feed' &&
          post.status == 'active' &&
          post.visibility == 'authenticated' &&
          post.schemaVersion == 1 &&
          post.imagePaths is list &&
          post.imagePaths.hasAny([objectPath()]);
      }

      allow read: if request.auth != null &&
        validPostId() &&
        postAllowsRead();

      allow create: if request.auth != null &&
        request.auth.uid == uid &&
        validPostId() &&
        validFeedImage();

      allow update, delete: if false;
    }

  }
}

// === 콘솔 적용 방법 ===
// 1. Firebase 콘솔 → Storage → 규칙(Rules) 탭
// 2. 이 파일 내용을 붙여넣고 "게시(Publish)" 클릭
// 또는 Firebase CLI: firebase deploy --only storage
