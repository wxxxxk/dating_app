rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 가치관 답변(valueAnswers) 화이트리스트 검증. users/publicProfiles 공용.
    //
    // 계약: Map<questionKey, answerKey>. 문항별 단일 답변, 부분 응답·빈 map 허용.
    // - 필드가 없으면 유효(기존 문서·구버전 앱 호환).
    // - 있으면 반드시 map이고 key는 6개 질문 key의 부분집합.
    // - 존재하는 각 key의 값은 해당 질문의 answer key 중 하나여야 한다.
    // - 임의 question key, 교차 answer key, 숫자/bool/list/중첩 map 값은 거부된다
    //   (문자열이 아닌 값은 answer key 리스트의 `in` 검사에서 자동 탈락).
    function valueAnswersValid(data) {
      return !('valueAnswers' in data) || (
        data.valueAnswers is map &&
        data.valueAnswers.keys().hasOnly([
          'contact_frequency',
          'conflict_style',
          'date_style',
          'alone_time',
          'affection_expression',
          'life_rhythm'
        ]) &&
        (!('contact_frequency' in data.valueAnswers) ||
          data.valueAnswers.contact_frequency in [
            'all_day', 'few_times', 'once_a_day', 'when_needed'
          ]) &&
        (!('conflict_style' in data.valueAnswers) ||
          data.valueAnswers.conflict_style in [
            'talk_now', 'cool_down', 'text_first', 'soften'
          ]) &&
        (!('date_style' in data.valueAnswers) ||
          data.valueAnswers.date_style in [
            'active', 'cozy', 'foodie', 'culture'
          ]) &&
        (!('alone_time' in data.valueAnswers) ||
          data.valueAnswers.alone_time in [
            'a_lot', 'some', 'little', 'together'
          ]) &&
        (!('affection_expression' in data.valueAnswers) ||
          data.valueAnswers.affection_expression in [
            'words', 'actions', 'gifts', 'time'
          ]) &&
        (!('life_rhythm' in data.valueAnswers) ||
          data.valueAnswers.life_rhythm in [
            'morning', 'night', 'flexible'
          ])
      );
    }

    // 이야기 카드(profileStories) 화이트리스트 검증. users/publicProfiles 공용.
    //
    // 계약: List<{ promptKey, answer }>. 최대 3개, 순서가 표시 순서.
    // - 필드가 없으면 유효(기존 문서·구버전 앱 호환).
    // - 있으면 반드시 list이고, null/map/string 배열은 거부된다.
    // - promptKey는 고정 8개 catalog key만 허용한다.
    // - answer는 1~100자 문자열만 허용한다.
    // - 같은 promptKey 중복은 거부한다.
    function profileStoryPromptKeyValid(key) {
      return key in [
        'happy_moment',
        'weekend',
        'get_closer',
        'into_lately',
        'comfort_food',
        'travel_style',
        'small_happiness',
        'date_idea'
      ];
    }

    function profileStoryItemValid(item) {
      return item is map &&
        item.keys().hasOnly(['promptKey', 'answer']) &&
        item.keys().hasAll(['promptKey', 'answer']) &&
        item.promptKey is string &&
        profileStoryPromptKeyValid(item.promptKey) &&
        item.answer is string &&
        item.answer.size() >= 1 &&
        item.answer.size() <= 100;
    }

    function profileStoriesValid(data) {
      return !('profileStories' in data) || (
        data.profileStories is list &&
        (
          data.profileStories.size() == 0 ||
          (
            data.profileStories.size() == 1 &&
            profileStoryItemValid(data.profileStories[0])
          ) ||
          (
            data.profileStories.size() == 2 &&
            profileStoryItemValid(data.profileStories[0]) &&
            profileStoryItemValid(data.profileStories[1]) &&
            data.profileStories[0].promptKey !=
              data.profileStories[1].promptKey
          ) ||
          (
            data.profileStories.size() == 3 &&
            profileStoryItemValid(data.profileStories[0]) &&
            profileStoryItemValid(data.profileStories[1]) &&
            profileStoryItemValid(data.profileStories[2]) &&
            data.profileStories[0].promptKey !=
              data.profileStories[1].promptKey &&
            data.profileStories[0].promptKey !=
              data.profileStories[2].promptKey &&
            data.profileStories[1].promptKey !=
              data.profileStories[2].promptKey
          )
        )
      );
    }

    // users/{uid} 문서:
    // - 본인만 읽을 수 있다. 다른 사용자 표시 정보는 publicProfiles/{uid}를
    //   사용한다.
    // - create/update는 Phase 0-C부터 명시적 필드 화이트리스트로 제한한다.
    // - verifications는 Phase 0-D부터 서버 검증(Cloud Functions/Admin SDK)
    //   전용이다. 클라이언트 create는 정확한 false 초기값만 허용하고,
    //   owner update/delete/null/key 변경은 모두 거부한다.
    match /users/{uid} {
      function userCreateKeys() {
        return [
          'displayName', 'birthDate', 'gender', 'bio', 'photoUrls',
          'createdAt', 'updatedAt', 'height', 'religion', 'smoking',
          'drinking', 'jobCategory', 'jobTitle', 'education', 'mbti',
          'interests', 'personalityTags', 'idealTags', 'relationshipGoal',
          'valueAnswers', 'profileStories',
          'location', 'verifications', 'discoveryFilter',
          'fcmTokens', 'fcmTokenUpdatedAt'
        ];
      }

      function userOwnerUpdateKeys() {
        return [
          'displayName', 'gender', 'bio', 'photoUrls', 'height', 'religion',
          'smoking', 'drinking', 'jobCategory', 'jobTitle', 'education',
          'mbti', 'interests', 'personalityTags', 'idealTags',
          'relationshipGoal', 'valueAnswers', 'profileStories', 'updatedAt',
          'location', 'discoveryFilter', 'fcmTokens', 'fcmTokenUpdatedAt'
        ];
      }

      function locationValid(data) {
        return !('location' in data) ||
          data.location == null || (
            data.location is map &&
            data.location.keys().hasOnly(['lat', 'lng', 'updatedAt', 'label']) &&
            data.location.keys().hasAll(['lat', 'lng', 'updatedAt']) &&
            data.location.lat is number &&
            data.location.lat >= -90 && data.location.lat <= 90 &&
            data.location.lng is number &&
            data.location.lng >= -180 && data.location.lng <= 180 &&
            data.location.updatedAt is timestamp &&
            (!('label' in data.location) ||
              data.location.label == null ||
              data.location.label is string)
          );
      }

      function initialVerificationsValid(data) {
        return 'verifications' in data &&
          data.verifications is map &&
          data.verifications.keys().hasOnly(['email', 'phone', 'photo']) &&
          data.verifications.keys().hasAll(['email', 'phone', 'photo']) &&
          data.verifications.email is bool &&
          data.verifications.email == false &&
          data.verifications.phone is bool &&
          data.verifications.phone == false &&
          data.verifications.photo is bool &&
          data.verifications.photo == false;
      }

      function discoveryFilterValid(data) {
        return !('discoveryFilter' in data) ||
          data.discoveryFilter == null || (
            data.discoveryFilter is map &&
            data.discoveryFilter.keys().hasOnly([
              'ageMin', 'ageMax', 'maxDistanceKm', 'gender', 'relationshipGoal'
            ]) &&
            (!('ageMin' in data.discoveryFilter) ||
              (data.discoveryFilter.ageMin is int &&
                data.discoveryFilter.ageMin >= 18 &&
                data.discoveryFilter.ageMin <= 80)) &&
            (!('ageMax' in data.discoveryFilter) ||
              (data.discoveryFilter.ageMax is int &&
                data.discoveryFilter.ageMax >= 18 &&
                data.discoveryFilter.ageMax <= 80)) &&
            (!('maxDistanceKm' in data.discoveryFilter) ||
              data.discoveryFilter.maxDistanceKm == null ||
              data.discoveryFilter.maxDistanceKm is number) &&
            (!('gender' in data.discoveryFilter) ||
              data.discoveryFilter.gender in ['male', 'female', 'all']) &&
            (!('relationshipGoal' in data.discoveryFilter) ||
              data.discoveryFilter.relationshipGoal == null ||
              data.discoveryFilter.relationshipGoal in [
                'casual_friend', 'light_romance',
                'serious_relationship', 'open_to_anything'
              ])
          );
      }

      function userFieldsValid(data) {
        return (!('displayName' in data) || data.displayName is string) &&
          (!('birthDate' in data) || data.birthDate is timestamp) &&
          (!('gender' in data) ||
            data.gender in ['male', 'female', 'other']) &&
          (!('bio' in data) || data.bio is string) &&
          (!('photoUrls' in data) ||
            (data.photoUrls is list && data.photoUrls.size() <= 4)) &&
          (!('createdAt' in data) || data.createdAt is timestamp) &&
          (!('updatedAt' in data) || data.updatedAt is timestamp) &&
          (!('height' in data) ||
            data.height == null ||
            (data.height is int && data.height >= 0 && data.height <= 300)) &&
          (!('interests' in data) ||
            (data.interests is list && data.interests.size() <= 8)) &&
          (!('personalityTags' in data) ||
            (data.personalityTags is list &&
              data.personalityTags.size() <= 8)) &&
          (!('idealTags' in data) ||
            (data.idealTags is list && data.idealTags.size() <= 8)) &&
          (!('fcmTokens' in data) ||
            (data.fcmTokens is list && data.fcmTokens.size() <= 20)) &&
          (!('fcmTokenUpdatedAt' in data) ||
            data.fcmTokenUpdatedAt == request.time) &&
          locationValid(data) &&
          initialVerificationsValid(data) &&
          discoveryFilterValid(data) &&
          valueAnswersValid(data) &&
          profileStoriesValid(data);
      }

      function changedUserFieldsValid(changed) {
        return (!changed.hasAny(['displayName']) ||
            request.resource.data.displayName is string) &&
          (!changed.hasAny(['gender']) ||
            request.resource.data.gender in ['male', 'female', 'other']) &&
          (!changed.hasAny(['bio']) ||
            request.resource.data.bio is string) &&
          (!changed.hasAny(['photoUrls']) ||
            (request.resource.data.photoUrls is list &&
              request.resource.data.photoUrls.size() <= 4)) &&
          (!changed.hasAny(['updatedAt']) ||
            request.resource.data.updatedAt is timestamp) &&
          (!changed.hasAny(['height']) ||
            request.resource.data.height == null ||
            (request.resource.data.height is int &&
              request.resource.data.height >= 0 &&
              request.resource.data.height <= 300)) &&
          (!changed.hasAny(['interests']) ||
            (request.resource.data.interests is list &&
              request.resource.data.interests.size() <= 8)) &&
          (!changed.hasAny(['personalityTags']) ||
            (request.resource.data.personalityTags is list &&
              request.resource.data.personalityTags.size() <= 8)) &&
          (!changed.hasAny(['idealTags']) ||
            (request.resource.data.idealTags is list &&
              request.resource.data.idealTags.size() <= 8)) &&
          (!changed.hasAny(['fcmTokens']) ||
            (request.resource.data.fcmTokens is list &&
              request.resource.data.fcmTokens.size() <= 20)) &&
          (!changed.hasAny(['fcmTokenUpdatedAt']) ||
            request.resource.data.fcmTokenUpdatedAt == request.time) &&
          (!changed.hasAny(['location']) ||
            locationValid(request.resource.data)) &&
          (!changed.hasAny(['discoveryFilter']) ||
            discoveryFilterValid(request.resource.data)) &&
          // valueAnswers를 건드리는 update는 결과 문서에 valueAnswers가 여전히
          // map으로 존재하고 유효해야 한다 — 필드 삭제(FieldValue.delete)는 거부.
          // 답변 전체 삭제는 {} 저장으로 처리한다.
          (!changed.hasAny(['valueAnswers']) ||
            ('valueAnswers' in request.resource.data &&
              valueAnswersValid(request.resource.data))) &&
          // profileStories를 건드리는 update는 결과 문서에 profileStories가
          // 여전히 list로 존재하고 유효해야 한다 — 필드 삭제는 거부.
          // 카드 전체 초기화는 [] 저장으로 처리한다.
          (!changed.hasAny(['profileStories']) ||
            ('profileStories' in request.resource.data &&
              profileStoriesValid(request.resource.data)));
      }

      function isAllowedJellySpendUpdate() {
        let changed = request.resource.data.diff(resource.data).affectedKeys();
        let before = resource.data.get('jelly', 0);
        let after = request.resource.data.get('jelly', -1);
        let cost = before - after;
        return before is int &&
          after is int &&
          after >= 0 &&
          cost > 0 &&
          (
            (changed.hasOnly(['jelly']) && cost in [3, 5]) ||
            (
              changed.hasOnly(['jelly', 'boostUntil']) &&
              cost == 30 &&
              request.resource.data.get('boostUntil', null) is timestamp &&
              request.resource.data.get('boostUntil', null) > request.time &&
              request.resource.data.get('boostUntil', null) <=
                request.time + duration.value(31, 'm')
            ) ||
            (
              changed.hasOnly(['jelly', 'likesUnlocked']) &&
              cost == 20 &&
              request.resource.data.get('likesUnlocked', false) == true &&
              resource.data.get('likesUnlocked', false) != true
            )
          );
      }

      allow read: if request.auth != null && request.auth.uid == uid;

      allow create: if request.auth != null &&
        request.auth.uid == uid &&
        request.resource.data.keys().hasOnly(userCreateKeys()) &&
        userFieldsValid(request.resource.data);

      allow update: if request.auth != null &&
        request.auth.uid == uid &&
        (
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(userOwnerUpdateKeys()) &&
            changedUserFieldsValid(
              request.resource.data.diff(resource.data).affectedKeys()
            )
          ) ||
          isAllowedJellySpendUpdate()
        );

      allow delete: if false;

      // 더미(dummy_*) 사용자 문서에 대한 예외 write 규칙은 제거됐다.
      // Firestore 규칙은 클라이언트의 kDebugMode와 무관하게 항상 적용되므로,
      // dummy_* 예외를 두면 release 빌드에서도 인증된 모든 유저가 남의 문서에
      // 쓸 수 있는 계정 오염/탈취 경로가 된다. 더미 데이터가 필요한 개발
      // 시나리오는 Firebase Emulator 또는 Admin SDK seed 도구로 처리해야 하며,
      // 프로덕션 규칙을 완화하지 않는다(lib/dev/dummy_data_service.dart 참고).

      // users/{uid}/swipes/{targetUid}:
      // - 본인의 스와이프 기록만 읽고 쓸 수 있다.
      // - 매칭 판정은 Cloud Functions admin SDK가 처리한다.
      // - 다른 사용자(더미 포함) 명의의 스와이프는 생성/수정할 수 없다.
      match /swipes/{targetUid} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // users/{uid}/dailyFortune/{yyyy-MM-dd} (M6.5):
      // - 오늘의 운세(애정 중심) 캐시. 본인만 읽을 수 있다.
      // - 쓰기는 Cloud Functions(admin SDK, generateDailyFortune)만 가능 —
      //   클라이언트가 직접 GPT 호출을 우회해 위조하지 못하게 막는다.
      match /dailyFortune/{date} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }

      // users/{uid}/blocks/{blockedUid}:
      // - 본인만 자신의 차단 목록을 읽고 쓸 수 있다.
      // - blockerUid/blockedUid를 문서 경로와 맞춰 저장해 collectionGroup 조회 시
      //   "나를 차단한 사람"을 안전하게 판별한다.
      match /blocks/{blockedUid} {
        allow read, delete: if request.auth != null && request.auth.uid == uid;
        allow create, update: if request.auth != null &&
          request.auth.uid == uid &&
          request.resource.data.blockerUid == uid &&
          request.resource.data.blockedUid == blockedUid;
      }

      // users/{uid}/jellyTransactions/{txId}:
      // 결제 지급 기록은 verifyJellyPurchase가 영수증 검증 후 Admin SDK로만
      // 생성한다. 클라이언트는 기존 젤리 사용(spend) 내역만 제한적으로 만들 수
      // 있고, charge/receipt 성격의 지급 기록은 직접 만들거나 고칠 수 없다.
      match /jellyTransactions/{txId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create: if request.auth != null &&
          request.auth.uid == uid &&
          request.resource.data.keys().hasOnly([
            'type', 'amount', 'reason', 'createdAt'
          ]) &&
          request.resource.data.type == 'spend' &&
          request.resource.data.amount is int &&
          request.resource.data.amount in [-3, -5, -20, -30] &&
          request.resource.data.reason is string &&
          request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }
    }

    // publicProfiles/{uid} (Phase 0-B):
    // - 다른 인증 사용자에게 공개되는 최소 프로필. 정확 birthDate/정확 위치/
    //   재화/토큰/AI 캐시는 절대 담기지 않는다(PublicProfile 계약).
    // - read: 인증 사용자만. 비로그인 거부.
    // - create/update: 본인만, owner-editable 필드만. server-managed 필드
    //   (verifications/rankingBoostUntil/profileUpdatedAt/schemaVersion)와
    //   알 수 없는 key는 클라이언트가 생성·변경할 수 없다(서버/Admin 전용).
    // - delete: 클라이언트 금지(탈퇴/backfill은 Admin SDK가 규칙을 우회).
    //
    // users/{uid} 타인 read는 닫혀 있다. 다른 사용자 표시 정보는 이 경로만
    // 사용해야 한다.
    match /publicProfiles/{uid} {
      // PublicProfile.ownerEditableKeys와 정확히 일치해야 한다.
      function ownerEditableKeys() {
        return [
          'displayName', 'age', 'gender', 'bio', 'photoUrls', 'height',
          'religion', 'smoking', 'drinking', 'jobCategory', 'jobTitle',
          'education', 'mbti', 'interests', 'personalityTags', 'idealTags',
          'relationshipGoal', 'valueAnswers', 'profileStories',
          'coarseLocation'
        ];
      }

      // 누락 필드에 안전 접근하도록 Map.get / key 존재 검사를 사용한다.
      function coarseLocationValid(data) {
        return !('coarseLocation' in data) ||
          data.coarseLocation == null || (
            data.coarseLocation is map &&
            // 세 key가 모두 존재하고 그 외 key는 없어야 한다(불완전/추가 key 거부).
            // 앱은 CoarseLocation.toMap()으로 항상 lat/lng/updatedAt을 함께 쓴다.
            data.coarseLocation.keys().hasOnly(['lat', 'lng', 'updatedAt']) &&
            data.coarseLocation.keys().hasAll(['lat', 'lng', 'updatedAt']) &&
            data.coarseLocation.lat is number &&
            data.coarseLocation.lat >= -90 && data.coarseLocation.lat <= 90 &&
            data.coarseLocation.lng is number &&
            data.coarseLocation.lng >= -180 && data.coarseLocation.lng <= 180 &&
            data.coarseLocation.updatedAt is timestamp
          );
      }

      // 존재하는 owner 필드만 형식 검증한다(부분 문서 허용).
      function publicFieldsValid(data) {
        return (!('age' in data) ||
            (data.age is int && data.age >= 0 && data.age <= 130)) &&
          (!('gender' in data) ||
            data.gender in ['male', 'female', 'other']) &&
          (!('photoUrls' in data) ||
            (data.photoUrls is list && data.photoUrls.size() <= 4)) &&
          (!('interests' in data) ||
            (data.interests is list && data.interests.size() <= 8)) &&
          (!('personalityTags' in data) ||
            (data.personalityTags is list &&
              data.personalityTags.size() <= 8)) &&
          (!('idealTags' in data) ||
            (data.idealTags is list && data.idealTags.size() <= 8)) &&
          valueAnswersValid(data) &&
          profileStoriesValid(data) &&
          coarseLocationValid(data);
      }

      function changedPublicFieldsValid(changed) {
        return
          // profileStories를 건드리는 update는 결과 문서에 profileStories가
          // 여전히 list로 존재하고 유효해야 한다 — 필드 삭제는 거부.
          // 카드 전체 초기화는 [] 저장으로 처리한다.
          (!changed.hasAny(['profileStories']) ||
            ('profileStories' in request.resource.data &&
              profileStoriesValid(request.resource.data)));
      }

      allow read: if request.auth != null;

      // create: 전체 문서가 owner-editable 필드의 부분집합이어야 한다 —
      // server-managed 필드나 알 수 없는 key, uid 본문 저장을 모두 막는다.
      allow create: if request.auth != null &&
        request.auth.uid == uid &&
        request.resource.data.keys().hasOnly(ownerEditableKeys()) &&
        publicFieldsValid(request.resource.data);

      // update: 이번 write가 건드리는 key가 owner-editable에만 한정.
      // server-managed 필드를 바꾸려 하면 affectedKeys에 잡혀 거부된다.
      allow update: if request.auth != null &&
        request.auth.uid == uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(ownerEditableKeys()) &&
        changedPublicFieldsValid(
          request.resource.data.diff(resource.data).affectedKeys()
        ) &&
        publicFieldsValid(request.resource.data);

      allow delete: if false;
    }

    // matches/{matchId}:
    // - 읽기(get): 매치의 participants 중 한 명인 유저만 가능.
    //   resource == null 이면 문서가 존재하지 않는 것(매치 미성사).
    //   이 경우도 허용해야 checkForMatch가 "문서 없음(exists=false)"을 정상 반환한다.
    //   resource == null 을 막으면 Firestore가 PERMISSION_DENIED를 반환해,
    //   like 스와이프마다 오류처럼 보이는 버그가 생긴다.
    // - list: 필요 시 watchMatches에서 arrayContains 쿼리를 사용하므로
    //   list 도 participants 기반으로 허용한다.
    //   (쿼리는 Firestore가 규칙을 문서별로 평가하므로 실질적으로 안전하다.)
    // - 쓰기: Cloud Functions(admin SDK)만 가능 — 클라이언트는 직접 생성·수정 불가.
    //
    // matchId = [uid1, uid2].sort().join('_') 형식.
    // Firestore 복합 인덱스 필요:
    //   Collection: matches / participants(arrayContains) + matchedAt(desc)
    //   앱 실행 시 콘솔에 인덱스 생성 URL이 출력되면 해당 URL을 열어 인덱스를 만들 것.
    match /matches/{matchId} {
      function isParticipant() {
        return request.auth != null &&
          request.auth.uid in resource.data.participants;
      }

      function changesOnlyOwnLastReadAt() {
        let before = resource.data.get('lastReadAtByUid', {});
        let after = request.resource.data.get('lastReadAtByUid', {});
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastReadAtByUid']) &&
          after.diff(before).affectedKeys().hasOnly([request.auth.uid]) &&
          after[request.auth.uid] == request.time;
      }

      // celebratedBy: 매칭 축하(MatchCelebrationOverlay)를 봤다고 표시하는 배열.
      // 본인 uid를 끝에 arrayUnion으로 추가하는 쓰기만 허용한다 — 다른 사람 uid를
      // 대신 추가하거나, 이미 있던 항목을 지우거나 순서를 바꾸는 쓰기는 막는다.
      function changesOnlyOwnCelebratedBy() {
        let before = resource.data.get('celebratedBy', []);
        let after = request.resource.data.celebratedBy;
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['celebratedBy']) &&
          (after == before || after == before.concat([request.auth.uid]));
      }

      // unmatchedBy: 이 매칭을 더 이상 원하지 않는다고 표시하는 배열.
      // celebratedBy와 같은 패턴 — 본인 uid를 끝에 arrayUnion으로 추가하는
      // 쓰기만 허용한다. 한쪽이 넣은 uid를 상대방이나 본인이 다시 빼는 것도
      // 막는다 — "매칭 해제 취소" 기능은 없으므로 배열은 늘어나기만 해야 한다.
      function changesOnlyOwnUnmatchedBy() {
        let before = resource.data.get('unmatchedBy', []);
        let after = request.resource.data.unmatchedBy;
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['unmatchedBy']) &&
          (after == before || after == before.concat([request.auth.uid]));
      }

      allow get: if request.auth != null && (
        resource == null ||
        request.auth.uid in resource.data.participants
      );
      allow list: if request.auth != null && (
        resource == null ||
        request.auth.uid in resource.data.participants
      );
      allow create, delete: if false;

      // update:
      // - lastMessage 필드만 갱신 허용 (M5 채팅 전송 시 미리보기 갱신용) — 단,
      //   이 매칭이 아직 해제되지 않았을 때만. sendMessage()는 항상 메시지
      //   create와 이 update를 한 batch로 묶어 보내므로, 정상 전송 흐름에는
      //   영향이 없다(둘 다 이미 unmatchedBy가 빈 상태에서만 통과하던 조건이라
      //   동일 기준을 여기 한 곳에 더 추가하는 것뿐). 이 조건이 없으면 이미
      //   해제된 매칭에 실제 메시지 문서 없이 lastMessage만 단독으로 조작해
      //   가짜 미리보기를 남길 수 있었다.
      // - lastReadAtByUid는 본인 uid 키 하나만 갱신 허용 (매칭 목록 안읽음 표시용).
      // - celebratedBy는 본인 uid를 끝에 추가하는 쓰기만 허용 (매칭 축하 중복/비대칭 표시 방지용).
      // - unmatchedBy는 본인 uid를 끝에 추가하는 쓰기만 허용 (매칭 해제용).
      // matchedAt·participants 등 나머지 필드는 여전히 Cloud Functions만 쓸 수 있다 —
      // affectedKeys()와 map diff로 이번 쓰기가 건드리는 필드를 좁힌다.
      allow update: if isParticipant() && (
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastMessage']) &&
          resource.data.get('unmatchedBy', []).size() == 0) ||
        changesOnlyOwnLastReadAt() ||
        changesOnlyOwnCelebratedBy() ||
        changesOnlyOwnUnmatchedBy()
      );

      // matches/{matchId}/messages/{messageId}:
      // - read: 이 매치의 participants 중 한 명만 가능.
      // - create: participants 중 한 명 + senderId가 본인 uid와 일치 + 이 매칭이
      //   아직 해제(unmatch)되지 않았을 때만(둘 중 누구든 해제하면 새 메시지 생성이
      //   서버 단에서도 막힌다 — 클라이언트 UI를 우회해도 뚫리지 않는다).
      // - update/delete: 항상 금지 — 메시지 수정·삭제 기능은 아직 없다.
      //
      // 부모 matches 문서를 get()으로 조회한다. 같은 문서를 같은 요청 안에서
      // 여러 번 get()해도 Firestore 규칙 엔진이 결과를 재사용하므로(memoized)
      // 추가 문서 읽기는 실질적으로 1회다.
      match /messages/{messageId} {
        allow read: if request.auth != null &&
          request.auth.uid in
            get(/databases/$(database)/documents/matches/$(matchId)).data.participants;

        allow create: if request.auth != null &&
          request.auth.uid in
            get(/databases/$(database)/documents/matches/$(matchId)).data.participants &&
          request.resource.data.senderId == request.auth.uid &&
          get(/databases/$(database)/documents/matches/$(matchId)).data.get('unmatchedBy', []).size() == 0;

        allow update, delete: if false;
      }
    }

    // collectionGroup('swipes') 조회용 규칙:
    // 받은 좋아요 화면은 users/{다른유저}/swipes/{내uid} 문서를 collectionGroup으로
    // 읽는다. 남의 스와이프 전체를 열지 않고, targetUid가 본인인 문서만 허용한다.
    match /{path=**}/swipes/{swipeId} {
      allow read: if request.auth != null &&
        resource.data.targetUid == request.auth.uid;
    }

    // collectionGroup('blocks') 조회용 규칙:
    // 양방향 숨김을 위해 "나를 차단한 사람"만 읽을 수 있게 제한한다.
    match /{path=**}/blocks/{blockedUid} {
      allow read: if request.auth != null &&
        resource.data.blockedUid == request.auth.uid;
    }

    // reports/{reportId}:
    // 클라이언트는 신고 생성만 가능하고, 신고 목록 읽기/수정/삭제는 금지한다.
    // 운영자 검토 화면은 별도 관리자 권한 또는 Admin SDK로 붙이는 전제다.
    match /reports/{reportId} {
      allow create: if request.auth != null &&
        request.resource.data.keys().hasOnly([
          'reporterUid',
          'reportedUid',
          'reason',
          'detail',
          'createdAt'
        ]) &&
        request.resource.data.reporterUid == request.auth.uid &&
        request.resource.data.reportedUid is string &&
        request.resource.data.reason in [
          'inappropriate_photo',
          'abusive_language',
          'spam_scam',
          'impersonation',
          'other'
        ];
      allow read, update, delete: if false;
    }

  }
}

// === 콘솔 적용 방법 ===
// 1. Firebase 콘솔 (https://console.firebase.google.com) → 프로젝트 선택
// 2. 왼쪽 메뉴 → Firestore Database → 규칙(Rules) 탭
// 3. 이 파일 내용을 붙여넣고 "게시(Publish)" 클릭
// 또는 Firebase CLI가 설치돼 있으면: firebase deploy --only firestore:rules
